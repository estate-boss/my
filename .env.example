# AGGRESSIVE PROFIT HUNTER BOT - Environment Configuration
# =========================================================================
# IMPORTANT: This is an EXAMPLE file. Copy to .env and fill in your actual keys.
# NEVER commit .env to git! Add to .gitignore
# KEEP THESE KEYS SECRET—treat like passwords!
# =========================================================================

# TELEGRAM
# Get from @BotFather on Telegram (/newbot command)
TELEGRAM_TOKEN=your_telegram_bot_token_here_example_123abc

# Your Telegram user ID (get from @userinfobot)
OWNER_TELEGRAM_ID=123456789

# =========================================================================
# BYBIT (Futures Trading)
# Create API key at https://www.bybit.com/en/ → Account → API
# Permissions needed: Position (read/write), Order (read/write), Wallet (read)
# For testnet: https://testnet.bybit.com
# =========================================================================
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# =========================================================================
# AI PROVIDERS
# =========================================================================

# Google Gemini (AI decision model #1)
# Generate at https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (AI decision model #2)
# Generate at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# CoinGecko (Breaking news & data endpoint - no API key required)
# CoinGecko public API: https://api.coingecko.com/api/v3
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# =========================================================================
# BOT MODES & LIMITS
# =========================================================================

# Paper mode: true (simulated trades, no real money), false (LIVE trading ⚠️)
# ALWAYS start with true until you've tested!
PAPER_MODE=true

# Minimum balance protection (pause if balance falls below)
MIN_BALANCE=20

# Profit withdrawal wallet (Bybit address for 60% profit transfers)
# Format: Bybit USDT address or blank to disable auto-withdrawal
PROFIT_WALLET_ADDRESS=

# Threshold for profit withdrawal (trigger when accumulated profit reaches this)
PROFIT_WITHDRAWAL_THRESHOLD=100

# =========================================================================
# OPTIONAL: Timezone (default: Africa/Lagos for Nigeria WAT)
# =========================================================================
WAT_TIMEZONE=Africa/Lagos

# =========================================================================
# TRADING CONFIGURATION (MAIN COINS ONLY)
# =========================================================================

# Main coins: BTC, ETH, SOL, BNB, ADA, XRP, DOGE, AVAX, POLYGON, LINK, LTC, BCH
# Bot only trades these to avoid low-cap manipulation
# Position size: 2% of balance (reduced from 3%)
# Leverage: /risk low=5x, /risk medium=15x (was 50x), /risk high=50x (was 100x)

# =========================================================================
# NOTES
# =========================================================================
# 1. Start with PAPER_MODE=true to test the bot safely
# 2. Minimum balance: $20 (was $100)
# 3. Never share your API keys or .env file
# 4. Keep .env in .gitignore
# 5. 60% of profits → your external wallet
# 6. 40% of profits → reinvested in bot
# 7. Use /withdraw command to track profit extraction
# 8. Test on Bybit Testnet first (uses testnet API keys)
# 9. Start small ($20-100) to learn the bot
# 10. MAIN COINS ONLY (BTC, ETH, SOL, etc.) for safety
